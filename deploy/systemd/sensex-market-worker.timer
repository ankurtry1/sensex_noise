[Unit]
Description=Start Sensex Noise market-worker around market open
Documentation=file:/opt/sensex-noise/deploy/README.md

[Timer]
# This timer assumes the VM timezone is Asia/Kolkata.
OnCalendar=Mon..Fri *-*-* 09:05:00
Unit=sensex-market-worker.service
AccuracySec=1min
RandomizedDelaySec=0
Persistent=false

[Install]
WantedBy=timers.target
