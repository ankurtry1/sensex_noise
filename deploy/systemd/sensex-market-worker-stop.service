[Unit]
Description=Stop Sensex Noise market-worker after market close
Documentation=file:/opt/sensex-noise/deploy/README.md
After=docker.service
Wants=docker.service

[Service]
Type=oneshot
User=sensexbot
WorkingDirectory=/opt/sensex-noise
Environment=TZ=Asia/Kolkata
ExecStart=/opt/sensex-noise/deploy/scripts/stop_market_worker.sh

[Install]
WantedBy=multi-user.target
