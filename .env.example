# Kite credentials
KITE_API_KEY=
KITE_API_SECRET=
# Daily access tokens are stored in TOKEN_STORE_PATH, not .env.
KITE_REQUEST_TOKEN=

# Engine runtime
POLL_INTERVAL_SECONDS=2
STARTING_CAPITAL=1000000
TRADING_MODE=paper
POSITION_SIZING_MODE=fixed
TRADE_QTY=500
ORDER_PRODUCT=MIS
CAPITAL_BUDGET=300000
USE_KITE_FUNDS=false

# Strategy baseline
TARGET_POINTS=3
ENTRY_BUFFER_POINTS=5
CALL_OFFSET_POINTS=-200
PUT_OFFSET_POINTS=200
UNDERLYING_SYMBOL=BSE:SENSEX
ENTRY_CUTOFF_TIME=14:55
ENTRY_WINDOW_SECONDS=40
ENTRY_WINDOW_MAX_SECONDS=10.0
ENTRY_FEATURE_LOOKBACK_SECONDS=5.0
POST_1PM_TIME_STOP_SECONDS=60
SESSION_SQUARE_OFF_ENABLED=false
SESSION_SQUARE_OFF_TIME=15:15

# Files
# Local default resolves to the repository root. Production can use /var/lib/sensex-noise.
DATA_DIR=
LOGS_DIR=
RUNTIME_DIR=
TOKEN_STORE_PATH=
INSTRUMENTS_CACHE_PATH=data/instruments.csv
TRADE_LOG_PATH=logs/trades.jsonl
CONTROL_PATH=runtime/control.json

# Auth web service
APP_BASE_URL=http://127.0.0.1:8000
ADMIN_TOKEN=

# New telemetry/logging outputs
ENABLE_VERBOSE_TRADE_LOGGING=true
EVENT_LOG_PATH=logs/events.jsonl
ENRICHED_TRADE_LOG_PATH=logs/trades_enriched.jsonl
FEATURES_OUTPUT_PATH=logs/features_daily.csv
ENABLE_SIGNAL_LOGGING=true
ENABLE_ENTRY_CONTEXT_LOGGING=true
ENABLE_SNAPSHOT_LOGGING=true
ENABLE_POST_EXIT_OBSERVATION=true
POST_EXIT_OBSERVATION_SECONDS=15
POST_EXIT_OBSERVATION_INTERVAL_SECONDS=1
SNAPSHOT_SECONDS=1,3,5,10,15,20,30,60

# Layer 0: hard stop
ENABLE_HARD_STOP=true
HARD_STOP_ARM_AFTER_SECONDS=30
HARD_STOP_POINTS=8
CONTINUATION_CALL_HARD_STOP_POINTS=6

# Pre-entry microburst gate + promoted-trade policy
ENABLE_MICROBURST_GATE=true
MICROBURST_MIN_SCORE=3
MICROBURST_IND_ACCEL_THRESHOLD_1=1.688
MICROBURST_IND_ACCEL_THRESHOLD_2=3.945
MICROBURST_OPT_VELOCITY_THRESHOLD=1.583
MICROBURST_OPT_DEPTH_IMB_THRESHOLD=0.0857
MICROBURST_IND_VELOCITY_MIN=1.646
MICROBURST_IND_VELOCITY_MAX=2.356
NORMAL_TARGET_POINTS=3.0
PROMOTED_MIN_SCORE=5
PROMOTED_TARGET_POINTS=7.0
PROMOTED_3S_MIN_RUNUP_POINTS=4.0
PROMOTED_3S_MIN_PNL_POINTS=1.5
PROMOTED_3S_MAX_MAE_POINTS=3.5
PROMOTED_3S_MIN_VELOCITY_DECAY_RATIO=0.5
LAYER4_ENABLED=true
LAYER4_TRIGGER_POINTS=3.0
LAYER4_REQUIRED_FOLLOWTHROUGH_POINTS=4.5
LAYER4_WINDOW_SECONDS=2.0

# Layer 1: early-risk
ENABLE_EARLY_RISK=true
EARLY_RISK_SUSPICION_SECONDS=5
EARLY_RISK_EXIT_SECONDS=10
EARLY_RISK_RUNUP_MAX_FOR_EXIT=1.0
EARLY_RISK_DRAWDOWN_MIN_FOR_EXIT=-3.0
EARLY_RISK_REQUIRE_BELOW_ENTRY=true
EARLY_RISK_SUSPICION_CURRENT_PNL=-2.0
EARLY_RISK_SUSPICION_REQUIRE_ADVERSE_FIRST_MOVE=false
EARLY_RISK_STRICT_AFTER_1PM=true

# Layer 2: path-risk
ENABLE_PATH_RISK=true
PATH_RISK_CHECK_SECONDS=30
PATH_RISK_PNL_MIN_FOR_EXIT=-6.0
PATH_RISK_RUNUP_MAX_FOR_EXIT=2.0
PATH_RISK_STRICT_AFTER_1PM=true
PATH_RISK_TIGHTEN_IF_FRAGILE=true

# Edge invalidation: fast early-fail framework
ENABLE_EDGE_INVALIDATION=true
EDGE_INVALIDATION_1S_ENABLED=true
EDGE_INVALIDATION_3S_ENABLED=true
EDGE_INVALIDATION_1S_CHECK_SECONDS=1.0
EDGE_INVALIDATION_3S_CHECK_SECONDS=3.0
EDGE_INVALIDATION_1S_MIN_RUNUP_POINTS=1.0
EDGE_INVALIDATION_1S_MAX_PNL_POINTS=0.0
EDGE_INVALIDATION_3S_MIN_RUNUP_POINTS=2.0
EDGE_INVALIDATION_3S_MAX_DRAWDOWN_POINTS=4.0
EDGE_INVALIDATION_3S_PINNED_PNL_ABS_POINTS=1.0
EDGE_INVALIDATION_HARD_STOP_ENABLED=true
EDGE_INVALIDATION_HARD_STOP_POINTS=6.0
EDGE_INVALIDATION_STALE_QUOTE_MAX_SECONDS=1.5
EDGE_INVALIDATION_KILL_ON_STALE_QUOTES=false
EDGE_INVALIDATION_REQUIRE_SUBSECOND_PRECISION=false
EDGE_INVALIDATION_USE_UNDERLYING_CONFIRMATION=false
EDGE_INVALIDATION_USE_SPREAD_FILTER=false
PREFER_EDGE_INVALIDATION_OVER_LEGACY_EARLY_RISK=true

# Dynamic target re-pricing for risky/fragile trades
ENABLE_DYNAMIC_RISKY_TARGET=true
RISKY_TARGET_POINTS=2.0
STRICT_AFTER_1PM_RISKY_TARGET_POINTS=2.0

# Optional future-friendly logging flags
ENABLE_ORDER_TIMELINE_LOGGING=true
ENABLE_QUOTE_LOGGING=true
ENABLE_VELOCITY_LOGGING=true
ENABLE_POST_EXIT_COUNTERFACTUAL=true
ENABLE_EXIT_DECISION_LOGGING=true
ENABLE_TARGET_REPRICE_MODIFY=true
ENABLE_TARGET_REPRICE_FALLBACK_CANCEL_REPLACE=true
ENABLE_SLIPPAGE_LOGGING=true
TARGET_REPRICE_DEBOUNCE_SECONDS=2

# Legacy option tape logging
# Keep this false to avoid duplicate option logs in logs/ticks/YYYY-MM-DD/options.jsonl.
# The broad research tape will be written separately under data/tape/sensex_options.
ENABLE_FULL_OPTION_TAPE_LOGGING=false

# Broad SENSEX option tape recorder for backtesting/research
# This subscribes to a wider SENSEX option lattice in addition to the strategy lattice.
ENABLE_SENSEX_OPTION_TAPE_RECORDER=true
SENSEX_TAPE_STRIKE_RANGE_POINTS=1500
SENSEX_TAPE_STRIKE_STEP_POINTS=100
SENSEX_TAPE_EXPIRY_MODE=nearest
SENSEX_TAPE_INCLUDE_CE=true
SENSEX_TAPE_INCLUDE_PE=true
SENSEX_TAPE_REBASE_ON_ATM_MOVE_POINTS=100
SENSEX_TAPE_LOG_DIR=data/tape/sensex_options

# Keep this false so the broad tape is not duplicated into legacy option logs.
SENSEX_TAPE_WRITE_LEGACY_OPTIONS_LOG=false

# Websocket runtime hardening
STREAM_WATCHDOG_MAX_IDLE_SECONDS=5
WATCHDOG_HARD_RECONNECT_SECONDS=8
STREAM_RECONNECT_COOLDOWN_SECONDS=10
STREAM_CONNECT_TIMEOUT_SECONDS=10
STREAM_FIRST_TICK_TIMEOUT_SECONDS=8
HEARTBEAT_LOG_INTERVAL_SECONDS=30
REBASE_PERSIST_TICKS=3
REBASE_COOLDOWN_SECONDS=3
REBASE_MIN_MOVE_POINTS=100
CRITICAL_TICK_QUEUE_MAXSIZE=5000

# Increased queues for broad option tape recording
BACKGROUND_TICK_QUEUE_MAXSIZE=100000
JOURNAL_QUEUE_MAXSIZE=200000
JOURNAL_FLUSH_INTERVAL_SECONDS=1

# Optional future control flags
WRITE_DAILY_FEATURES=true
WRITE_DAILY_POLICY_SIMULATION=false

# Legacy early-failure detector: kept for backward compatibility
EARLY_FAILURE_WINDOW_SECONDS=15
EARLY_FAILURE_MFE_MIN=1.5
EARLY_FAILURE_MAE_MAX=-1.5

LOG_LEVEL=INFO
